---
import { getLangFromUrl, useTranslations } from "@/i18n/utils"
import Event from "./Event.astro"
import { getCollection, render } from "astro:content"
import { cn } from "@/lib/utils"
import { badgeVariants } from "./ui/badge"

interface Props {
  type: "past" | "upcoming"
  displayType: "about" | "landing-page"
  class?: string
}

const { type, displayType = "about" } = Astro.props
const t = useTranslations(getLangFromUrl(Astro.url))
const lang = getLangFromUrl(Astro.url)
const getEntryPath = (item: { slug?: string; id?: string }) =>
  (item.slug ?? item.id ?? "").replace(/\.(md|mdx)$/, "")
const getCategorySlug = (category: string) =>
  category.toLowerCase().replace(/\s+/g, "-")

const events = (await getCollection("events"))
  .filter(
    (event) =>
      ("past" === type && event.data.endDate < new Date()) ||
      ("upcoming" === type && event.data.endDate >= new Date()),
  )
  .filter((item) => getEntryPath(item).startsWith(`${lang}/`))

const allCategories = [
  ...new Set(events.map((event) => event.data.category).filter(Boolean)),
].sort() as string[]

const uniqueId = `events-list-${Math.random().toString(36).slice(2)}`
const groupName = `filter-group-${uniqueId}`

// Setup Tailwind-only classes for known categories.
// We use a static map so Tailwind's scanner picks up the class strings.
const CATEGORY_STYLES: Record<
  string,
  { peer: string; label: string; hider: string }
> = {
  Talk: {
    peer: "peer/talk",
    label:
      "peer-checked/talk:[&_[data-category-filter='talk']]:bg-primary peer-checked/talk:[&_[data-category-filter='talk']]:text-primary-foreground peer-checked/talk:[&_[data-category-filter='talk']]:border-transparent",
    hider:
      "peer-checked/talk:[&_.event-item:not([data-category='talk'])]:hidden",
  },
  Workshop: {
    peer: "peer/workshop",
    label:
      "peer-checked/workshop:[&_[data-category-filter='workshop']]:bg-primary peer-checked/workshop:[&_[data-category-filter='workshop']]:text-primary-foreground peer-checked/workshop:[&_[data-category-filter='workshop']]:border-transparent",
    hider:
      "peer-checked/workshop:[&_.event-item:not([data-category='workshop'])]:hidden",
  },
  Event: {
    peer: "peer/event",
    label:
      "peer-checked/event:[&_[data-category-filter='event']]:bg-primary peer-checked/event:[&_[data-category-filter='event']]:text-primary-foreground peer-checked/event:[&_[data-category-filter='event']]:border-transparent",
    hider:
      "peer-checked/event:[&_.event-item:not([data-category='event'])]:hidden",
  },
  DIDAY: {
    peer: "peer/diday",
    label:
      "peer-checked/diday:[&_[data-category-filter='diday']]:bg-primary peer-checked/diday:[&_[data-category-filter='diday']]:text-primary-foreground peer-checked/diday:[&_[data-category-filter='diday']]:border-transparent",
    hider:
      "peer-checked/diday:[&_.event-item:not([data-category='diday'])]:hidden",
  },
  "Members meeting": {
    peer: "peer/members-meeting",
    label:
      "peer-checked/members-meeting:[&_[data-category-filter='members-meeting']]:bg-primary peer-checked/members-meeting:[&_[data-category-filter='members-meeting']]:text-primary-foreground peer-checked/members-meeting:[&_[data-category-filter='members-meeting']]:border-transparent",
    hider:
      "peer-checked/members-meeting:[&_.event-item:not([data-category='members-meeting'])]:hidden",
  },
  Miscellaneous: {
    peer: "peer/miscellaneous",
    label:
      "peer-checked/miscellaneous:[&_[data-category-filter='miscellaneous']]:bg-primary peer-checked/miscellaneous:[&_[data-category-filter='miscellaneous']]:text-primary-foreground peer-checked/miscellaneous:[&_[data-category-filter='miscellaneous']]:border-transparent",
    hider:
      "peer-checked/miscellaneous:[&_.event-item:not([data-category='miscellaneous'])]:hidden",
  },
}

const ALL_STYLES = {
  peer: "peer/all",
  label:
    "peer-checked/all:[&_[data-category-filter='all']]:bg-primary peer-checked/all:[&_[data-category-filter='all']]:text-primary-foreground peer-checked/all:[&_[data-category-filter='all']]:border-transparent",
}
---

{displayType === "about" && <h2 id={`${type}-events`}>{t(`event.${type}`)}</h2>}

<div class={cn("flex flex-col gap-4", Astro.props.class)} id={uniqueId}>
  {
    allCategories.length > 0 && (
      <>
        <input
          type="radio"
          name={groupName}
          id={`${uniqueId}-all`}
          class={cn("sr-only", ALL_STYLES.peer)}
          checked
        />
        {allCategories.map((category) => (
          <input
            type="radio"
            name={groupName}
            id={`${uniqueId}-${getCategorySlug(category)}`}
            class={cn("sr-only", CATEGORY_STYLES[category]?.peer)}
          />
        ))}

        <div
          class={cn(
            "flex flex-wrap gap-2 mb-4 filter-container",
            ALL_STYLES.label,
            ...allCategories.map((cat) => CATEGORY_STYLES[cat]?.label),
          )}
        >
          <label
            for={`${uniqueId}-all`}
            data-category-filter="all"
            class={cn(
              badgeVariants({ variant: "outline" }),
              "cursor-pointer hover:bg-muted",
            )}
          >
            {t("event.category.all")}
          </label>
          {allCategories.map((category) => (
            <label
              for={`${uniqueId}-${getCategorySlug(category)}`}
              data-category-filter={getCategorySlug(category)}
              class={cn(
                badgeVariants({ variant: "outline" }),
                "cursor-pointer hover:bg-muted",
              )}
            >
              {t(
                `event.category.${getCategorySlug(category)}` as any,
              )}
            </label>
          ))}
        </div>
      </>
    )
  }

  <div
    class={cn(
      "flex flex-col gap-4 events-list",
      // Add hider classes effectively as "global" rules for this container
      ...allCategories.map((cat) => CATEGORY_STYLES[cat]?.hider),
    )}
  >
    {events.length === 0 && <p>{t(`event.no-${type}`)}</p>}
    {
      events
        .toSorted((a, b) => {
          if (type === "upcoming") {
            return a.data.startDate < b.data.startDate ? -1 : 1
          }

          return a.data.startDate < b.data.startDate ? 1 : -1
        })
        .map(async (event) => {
          const { Content } = await render(event)
          const eventPath = getEntryPath(event)
          const categorySlug = event.data.category
            ? getCategorySlug(event.data.category)
            : undefined

          return (
            <div data-category={categorySlug} class="event-item block">
              <Event
                {...event.data}
                slug={eventPath}
                data-category={categorySlug}
              >
                <Content />
              </Event>
            </div>
          )
        })
    }
  </div>
</div>
