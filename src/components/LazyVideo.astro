---
// src/components/LazyVideo.astro
import { Image } from 'astro:assets';

export interface Props {
  embedUrl: string;
  thumbnail: ImageMetadata;
  alt: string;
  title: string;
  noticeText?: string;
}

const {
  embedUrl,
  thumbnail,
  alt,
  title,
  noticeText = "Clicking play loads a video from an external server.",
} = Astro.props;
---

<div class="lazy-video-container" data-embed-url={embedUrl} role="button" tabindex="0" aria-label={`Play video: ${title}`}>
  <Image src={thumbnail} alt={alt} class="video-thumbnail" loading="lazy" />
  <div class="play-button-overlay">
    <div class="play-button"></div>
    <div class="external-load-notice">{noticeText}</div>
  </div>
</div>

<style>
.lazy-video-container {
  position: relative;
  aspect-ratio: 16 / 9;
  cursor: pointer;
  overflow: hidden;
  border-radius: 0.5rem;
  background-color: #000;
  display: flex;
  justify-content: center;
  align-items: center;
}
.video-thumbnail {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.2s ease-in-out;
}
.lazy-video-container:hover .video-thumbnail {
  transform: scale(1.05);
}
.play-button-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.3);
  display: flex;
  justify-content: center;
  align-items: center;
  transition: background-color 0.2s ease-in-out;
}
.lazy-video-container:hover .play-button-overlay {
    background-color: rgba(0, 0, 0, 0.5);
}
.play-button {
  width: 60px;
  height: 60px;
  background-color: rgba(0, 0, 0, 0.7);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 0 20px rgba(0,0,0,0.5);
}
.play-button::after {
  content: '';
  display: block;
  width: 0;
  height: 0;
  border-style: solid;
  border-width: 12px 0 12px 20px;
  border-color: transparent transparent transparent white;
  margin-left: 4px;
}
.external-load-notice {
  position: absolute;
  bottom: 1rem;
  left: 1rem;
  right: 1rem;
  text-align: center;
  color: white;
  font-size: 0.75rem;
  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.7);
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.2s ease-in-out;
}
.lazy-video-container:hover .external-load-notice {
  opacity: 1;
}
</style>

<script>
  function initLazyVideo() {
    document.querySelectorAll('.lazy-video-container').forEach(container => {
      if (container.dataset.listenerAdded === 'true') {
        return;
      }
      container.dataset.listenerAdded = 'true';

      const clickHandler = (event) => {
        event.preventDefault();
        const embedUrl = container.dataset.embedUrl;
        if (!embedUrl) return;

        const iframe = document.createElement('iframe');
        const url = new URL(embedUrl);

        url.searchParams.set('autoplay', '1');
        url.searchParams.set('warningTitle', '0');
        // This line has been corrected
        url.searchParams.set('peertubeLink', '0');

        iframe.setAttribute('src', url.toString());
        iframe.setAttribute('title', container.getAttribute('aria-label') || 'Embedded Video');
        iframe.setAttribute('frameborder', '0');
        iframe.setAttribute('allow', 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share');
        iframe.setAttribute('allowfullscreen', 'true');
        iframe.setAttribute('sandbox', 'allow-same-origin allow-scripts allow-popups allow-forms');

        iframe.style.position = 'absolute';
        iframe.style.top = '0';
        iframe.style.left = '0';
        iframe.style.width = '100%';
        iframe.style.height = '100%';
        iframe.style.border = '0';

        container.innerHTML = '';
        container.appendChild(iframe);
      };

      container.addEventListener('click', clickHandler, { once: true });
      container.addEventListener('keydown', (event) => {
        if (event.key === 'Enter' || event.key === ' ') {
          clickHandler(event);
        }
      }, { once: true });
    });
  }

  initLazyVideo();
  document.addEventListener('astro:after-swap', initLazyVideo);
</script>
