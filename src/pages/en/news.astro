---
import { getCollection } from "astro:content"
import Layout from "../../layouts/Layout.astro"
import { getLangFromUrl } from "@/i18n/utils"

const lang = getLangFromUrl(Astro.url)
const getEntryPath = (item: { slug?: string; id?: string }) =>
  (item.slug ?? item.id ?? "").replace(/\.(md|mdx)$/, "")

const news = (await getCollection("news")).filter((item) =>
  getEntryPath(item).startsWith(`${lang}/`),
)
---

<Layout
  title={"News"}
  description={"List of news from Chaostreff Osnabrück"}
  lang={lang}
>
  <h2>News</h2>

  <ul>
    {
      news
        .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
        .map((item) => {
          const [lang, ...slug] = getEntryPath(item).split("/")

          return (
            <li>
              <a href={`/${lang}/news/${slug.join("/")}/`}>
                {new Date(item.data.date).toLocaleDateString(lang, {
                  dateStyle: "medium",
                })}{" "}
                - {item.data.title}
              </a>
            </li>
          )
        })
    }
  </ul>
</Layout>
